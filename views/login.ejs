<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>เข้าสู่ระบบ | ระบบบริหารจัดการโรงเรียน</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: { extend: { fontFamily: { kanit: ['Kanit', 'sans-serif'] } } }
    }
  </script>
</head>
<body class="font-kanit min-h-screen flex items-center justify-center p-4" style="background:#f4f5f9;">

  <%- include('partials/icons') %>

  <div class="w-full max-w-[360px]">

    <!-- Logo Header -->
    <div class="text-center mb-7">
      <div class="inline-flex items-center justify-center w-11 h-11 rounded-xl border border-slate-200/60 bg-white mb-4">
        <%- hi('academic-cap', 'h-5 w-5 text-slate-500') %>
      </div>
      <h1 class="text-lg font-bold text-slate-800 tracking-tight">ยินดีต้อนรับ</h1>
      <p class="text-slate-400 text-xs mt-1">ระบบบริหารจัดการโรงเรียนมัธยม</p>
    </div>

    <!-- Card — border only, no shadow -->
    <div class="bg-white rounded-xl border border-slate-200/60 p-7">

      <!-- Flash Messages -->
      <% if (error_msg && error_msg.length > 0) { %>
        <div class="flex items-start gap-2 bg-red-50 border border-red-200/60 text-red-600 rounded-lg px-3.5 py-3 mb-5 text-xs">
          <%- hi('exclamation-circle', 'h-3.5 w-3.5 mt-0.5 flex-shrink-0') %>
          <span><%= error_msg %></span>
        </div>
      <% } %>
      <% if (success_msg && success_msg.length > 0) { %>
        <div class="flex items-start gap-2 bg-emerald-50 border border-emerald-200/60 text-emerald-700 rounded-lg px-3.5 py-3 mb-5 text-xs">
          <%- hi('check-circle', 'h-3.5 w-3.5 mt-0.5 flex-shrink-0') %>
          <span><%= success_msg %></span>
        </div>
      <% } %>

      <form action="/login" method="POST" class="space-y-4">

        <div>
          <label for="username" class="block text-xs font-semibold text-slate-600 mb-1.5">ชื่อผู้ใช้</label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
              <%- hi('user', 'h-3.5 w-3.5') %>
            </div>
            <input
              type="text" id="username" name="username"
              placeholder="กรอกชื่อผู้ใช้" required autocomplete="username"
              class="w-full pl-9 pr-4 py-2.5 border border-slate-200/60 rounded-lg text-sm text-slate-800 placeholder-slate-400 bg-slate-50 focus:outline-none focus:ring-1 focus:ring-slate-300 focus:border-slate-300 focus:bg-white transition"
            >
          </div>
        </div>

        <div>
          <label for="password" class="block text-xs font-semibold text-slate-600 mb-1.5">รหัสผ่าน</label>
          <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
              <%- hi('lock-closed', 'h-3.5 w-3.5') %>
            </div>
            <input
              type="password" id="password" name="password"
              placeholder="กรอกรหัสผ่าน" required autocomplete="current-password"
              class="w-full pl-9 pr-4 py-2.5 border border-slate-200/60 rounded-lg text-sm text-slate-800 placeholder-slate-400 bg-slate-50 focus:outline-none focus:ring-1 focus:ring-slate-300 focus:border-slate-300 focus:bg-white transition"
            >
          </div>
        </div>

        <button
          type="submit"
          class="w-full py-2.5 bg-slate-800 hover:bg-slate-700 text-white font-semibold rounded-lg text-sm transition mt-1 flex items-center justify-center gap-2"
        >
          <%- hi('arrow-left-on-rectangle', 'h-4 w-4') %>เข้าสู่ระบบ
        </button>

      </form>
    </div>

    <p class="text-center font-mono text-[10px] text-slate-400 mt-5">High School Management System · 2026</p>
  </div>

</body>
</html>
