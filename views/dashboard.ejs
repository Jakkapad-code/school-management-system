<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard | ระบบบริหารจัดการโรงเรียน</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: { extend: { fontFamily: { kanit: ['Kanit', 'sans-serif'] } } }
    }
  </script>
</head>
<body class="font-kanit bg-gray-50">

  <% var activePage = 'dashboard'; %>
  <%- include('partials/sidebar', { activePage }) %>

  <!-- Main content (offset by collapsed sidebar width) -->
  <div class="ml-16 flex flex-col h-screen overflow-hidden">

    <!-- Top Bar -->
    <header class="bg-white border-b border-gray-200 px-8 py-4 flex items-center justify-between flex-shrink-0">
      <div>
        <h1 class="text-sm font-semibold text-gray-900 tracking-tight">หน้าหลัก</h1>
        <p class="text-[11px] text-gray-400 mt-0.5">ภาพรวมระบบบริหารจัดการโรงเรียน</p>
      </div>
      <div class="flex items-center gap-3">
        <div class="text-right">
          <p class="text-xs font-semibold text-gray-700"><%= currentUser.username %></p>
          <p class="text-[11px] text-gray-400"><%= currentUser.role %></p>
        </div>
        <div class="w-8 h-8 rounded-full bg-gray-100 border border-gray-200 flex items-center justify-center">
          <%- hi('user', 'h-3.5 w-3.5 text-gray-500') %>
        </div>
      </div>
    </header>

    <!-- Content -->
    <main class="flex-1 overflow-y-auto p-8">

      <!-- Flash -->
      <% if (success_msg && success_msg.length > 0) { %>
        <div class="flex items-center gap-2 bg-emerald-50 border border-emerald-200 text-emerald-700 rounded-lg px-4 py-3 mb-6 text-xs">
          <%- hi('check-circle', 'h-3.5 w-3.5 flex-shrink-0') %><span><%= success_msg %></span>
        </div>
      <% } %>
      <% if (error_msg && error_msg.length > 0) { %>
        <div class="flex items-center gap-2 bg-red-50 border border-red-200 text-red-600 rounded-lg px-4 py-3 mb-6 text-xs">
          <%- hi('exclamation-circle', 'h-3.5 w-3.5 flex-shrink-0') %><span><%= error_msg %></span>
        </div>
      <% } %>

      <!-- Bento Grid — row 1 -->
      <div class="grid grid-cols-3 gap-4 mb-4">

        <!-- Welcome Card — col-span-2 -->
        <div class="col-span-2 bg-white rounded-xl border border-gray-200 p-7 flex items-center justify-between">
          <div>
            <p class="text-[9px] text-gray-400 font-semibold uppercase tracking-[0.18em] mb-2">สวัสดีครับ / ค่ะ</p>
            <h2 class="text-2xl font-bold text-gray-900 tracking-tight"><%= currentUser.username %></h2>
            <div class="inline-flex items-center gap-1.5 mt-3 px-2.5 py-1 rounded-md border border-gray-200 bg-gray-50">
              <%- hi('shield-check', 'h-3 w-3 text-gray-400') %>
              <span class="text-xs text-gray-500 font-medium"><%= currentUser.role %></span>
            </div>
          </div>
          <div class="text-right flex-shrink-0 ml-6">
            <div class="w-14 h-14 rounded-xl bg-gray-100 border border-gray-200 flex items-center justify-center ml-auto mb-3">
              <%- hi('user', 'h-6 w-6 text-gray-400') %>
            </div>
            <p class="font-mono text-[10px] text-gray-400 tracking-tight">
              <%= new Date().toLocaleDateString('th-TH', { year: 'numeric', month: '2-digit', day: '2-digit' }) %>
            </p>
          </div>
        </div>

        <!-- Info Card — col-span-1 -->
        <div class="col-span-1 bg-white rounded-xl border border-gray-200 p-6 flex flex-col">
          <p class="text-[9px] text-gray-400 font-semibold uppercase tracking-[0.18em] mb-5">ข้อมูลระบบ</p>
          <div class="space-y-4 flex-1">
            <div>
              <p class="text-[9px] text-gray-400 uppercase tracking-wider mb-1">Version</p>
              <p class="font-mono text-xs text-gray-600 font-medium">v1.0.0</p>
            </div>
            <div>
              <p class="text-[9px] text-gray-400 uppercase tracking-wider mb-1">สถานะ</p>
              <div class="flex items-center gap-1.5">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 flex-shrink-0"></span>
                <span class="text-xs text-gray-600">ออนไลน์</span>
              </div>
            </div>
            <div>
              <p class="text-[9px] text-gray-400 uppercase tracking-wider mb-1">โมดูลที่ใช้งานได้</p>
              <p class="font-mono text-xs text-gray-600 font-medium">4 / 4</p>
            </div>
          </div>
          <div class="pt-4 border-t border-gray-100 mt-4">
            <p class="font-mono text-[9px] text-gray-400">HSM · Academic 2026</p>
          </div>
        </div>

      </div>

      <!-- Modules Section -->
      <div class="mb-3 flex items-center gap-3">
        <p class="text-[9px] font-semibold text-gray-400 uppercase tracking-[0.18em]">โมดูล</p>
        <div class="flex-1 h-px bg-gray-200"></div>
      </div>

      <!-- Bento Grid — row 2 -->
      <div class="grid grid-cols-4 gap-3">

        <!-- Teachers — active -->
        <a href="/teachers" class="group bg-white rounded-xl border border-gray-200 p-5 hover:border-gray-400 transition-all duration-200">
          <div class="w-9 h-9 bg-gray-50 border border-gray-200 group-hover:border-gray-300 rounded-xl flex items-center justify-center mb-4 transition-colors">
            <%- hi('academic-cap', 'h-4 w-4 text-gray-400 group-hover:text-gray-700 transition-colors') %>
          </div>
          <p class="font-semibold text-gray-700 text-sm leading-tight">จัดการครู</p>
          <p class="text-[11px] text-gray-400 mt-1">ดู เพิ่ม แก้ไข ลบ</p>
        </a>

        <!-- Students — active -->
        <a href="/students" class="group bg-white rounded-xl border border-gray-200 p-5 hover:border-gray-400 transition-all duration-200">
          <div class="w-9 h-9 bg-gray-50 border border-gray-200 group-hover:border-gray-300 rounded-xl flex items-center justify-center mb-4 transition-colors">
            <%- hi('users', 'h-4 w-4 text-gray-400 group-hover:text-gray-700 transition-colors') %>
          </div>
          <p class="font-semibold text-gray-700 text-sm leading-tight">จัดการนักเรียน</p>
          <p class="text-[11px] text-gray-400 mt-1">ดู เพิ่ม แก้ไข ลบ</p>
        </a>

        <!-- Subject — active -->
        <a href="/subjects" class="group bg-white rounded-xl border border-gray-200 p-5 hover:border-gray-400 transition-all duration-200">
          <div class="w-9 h-9 bg-gray-50 border border-gray-200 group-hover:border-gray-300 rounded-xl flex items-center justify-center mb-4 transition-colors">
            <%- hi('book-open', 'h-4 w-4 text-gray-400 group-hover:text-gray-700 transition-colors') %>
          </div>
          <p class="font-semibold text-gray-700 text-sm leading-tight">จัดการวิชา</p>
          <p class="text-[11px] text-gray-400 mt-1">ดู เพิ่ม แก้ไข ลบ</p>
        </a>

        <!-- Schedule — active -->
        <a href="/schedules" class="group bg-white rounded-xl border border-gray-200 p-5 hover:border-gray-400 transition-all duration-200">
          <div class="w-9 h-9 bg-gray-50 border border-gray-200 group-hover:border-gray-300 rounded-xl flex items-center justify-center mb-4 transition-colors">
            <%- hi('calendar-days', 'h-4 w-4 text-gray-400 group-hover:text-gray-700 transition-colors') %>
          </div>
          <p class="font-semibold text-gray-700 text-sm leading-tight">ตารางเรียน</p>
          <p class="text-[11px] text-gray-400 mt-1">ดู เพิ่ม แก้ไข ลบ</p>
        </a>

      </div>

    </main>
  </div>

</body>
</html>
