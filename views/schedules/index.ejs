<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | ระบบบริหารจัดการโรงเรียน</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: { extend: { fontFamily: { kanit: ['Kanit', 'sans-serif'] } } }
    }
  </script>
</head>
<body class="font-kanit bg-gray-50">

  <% var activePage = 'schedules'; %>
  <%- include('../partials/sidebar', { activePage }) %>

  <%
    const DAY_TH = { Monday:'จันทร์', Tuesday:'อังคาร', Wednesday:'พุธ',
                     Thursday:'พฤหัส', Friday:'ศุกร์', Saturday:'เสาร์', Sunday:'อาทิตย์' };
    const DAY_COLOR = {
      Monday:    'bg-blue-50 text-blue-600 border-blue-200/60',
      Tuesday:   'bg-pink-50 text-pink-600 border-pink-200/60',
      Wednesday: 'bg-emerald-50 text-emerald-600 border-emerald-200/60',
      Thursday:  'bg-orange-50 text-orange-600 border-orange-200/60',
      Friday:    'bg-yellow-50 text-yellow-700 border-yellow-200/60',
      Saturday:  'bg-purple-50 text-purple-600 border-purple-200/60',
      Sunday:    'bg-red-50 text-red-600 border-red-200/60',
    };
    const TYPE_TH = { Class:'เรียน', Meeting:'ประชุม', Other:'อื่นๆ' };
    const TYPE_COLOR = {
      Class:   'bg-slate-50 text-slate-600 border-slate-200/60',
      Meeting: 'bg-amber-50 text-amber-600 border-amber-200/60',
      Other:   'bg-slate-50 text-slate-400 border-slate-200/60',
    };
  %>

  <div class="ml-16 flex flex-col h-screen overflow-hidden">

    <header class="bg-white border-b border-slate-200/60 px-8 py-4 flex items-center justify-between flex-shrink-0">
      <div>
        <h1 class="text-sm font-semibold text-slate-800 tracking-tight">ตารางสอน</h1>
        <p class="text-[11px] text-slate-400 mt-0.5">
          <a href="/dashboard" class="hover:text-slate-600 transition-colors">หน้าหลัก</a>
          <span class="mx-1.5 text-slate-300">/</span>ตารางสอน
        </p>
      </div>
      <a href="/schedules/add" class="inline-flex items-center gap-1.5 px-3.5 py-2 bg-slate-800 hover:bg-slate-700 text-white font-semibold rounded-lg text-xs transition">
        <%- hi('plus', 'h-3.5 w-3.5') %>เพิ่มตารางสอน
      </a>
    </header>

    <main class="flex-1 overflow-y-auto p-8">

      <% if (success_msg && success_msg.length > 0) { %>
        <div class="flex items-center gap-2 bg-emerald-50 border border-emerald-200/60 text-emerald-700 rounded-lg px-4 py-3 mb-5 text-xs">
          <%- hi('check-circle', 'h-3.5 w-3.5 flex-shrink-0') %><span><%= success_msg %></span>
        </div>
      <% } %>
      <% if (error_msg && error_msg.length > 0) { %>
        <div class="flex items-center gap-2 bg-red-50 border border-red-200/60 text-red-600 rounded-lg px-4 py-3 mb-5 text-xs">
          <%- hi('exclamation-circle', 'h-3.5 w-3.5 flex-shrink-0') %><span><%= error_msg %></span>
        </div>
      <% } %>

      <div class="bg-white rounded-xl border border-slate-200/60 overflow-hidden">

        <div class="px-6 py-4 border-b border-slate-100">
          <div class="flex items-center gap-2.5">
            <div class="w-7 h-7 bg-slate-50 border border-slate-200/60 rounded-lg flex items-center justify-center">
              <%- hi('calendar-days', 'h-3.5 w-3.5 text-slate-500') %>
            </div>
            <div>
              <p class="font-semibold text-slate-700 text-sm">ตารางสอนทั้งหมด</p>
              <p class="font-mono text-[10px] text-slate-400"><%= schedules.length %> รายการ</p>
            </div>
          </div>
        </div>

        <% if (schedules.length === 0) { %>
          <div class="text-center py-16">
            <div class="w-12 h-12 bg-slate-50 border border-slate-200/60 rounded-xl flex items-center justify-center mx-auto mb-4">
              <%- hi('calendar-days', 'h-5 w-5 text-slate-400') %>
            </div>
            <p class="font-semibold text-slate-600 text-sm">ยังไม่มีตารางสอนในระบบ</p>
            <p class="text-slate-400 text-xs mt-1 mb-5">คลิกปุ่ม "เพิ่มตารางสอน" เพื่อเริ่มต้น</p>
            <a href="/schedules/add" class="inline-flex items-center gap-1.5 px-3.5 py-2 bg-slate-800 hover:bg-slate-700 text-white font-semibold rounded-lg text-xs transition">
              <%- hi('plus', 'h-3.5 w-3.5') %>เพิ่มตารางสอน
            </a>
          </div>
        <% } else { %>
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead>
                <tr class="border-b border-slate-100">
                  <th class="text-left py-3 px-5 text-[9px] font-semibold text-slate-400 uppercase tracking-wider w-14">ID</th>
                  <th class="text-left py-3 px-5 text-[9px] font-semibold text-slate-400 uppercase tracking-wider">วัน</th>
                  <th class="text-left py-3 px-5 text-[9px] font-semibold text-slate-400 uppercase tracking-wider">คาบ</th>
                  <th class="text-left py-3 px-5 text-[9px] font-semibold text-slate-400 uppercase tracking-wider">ประเภท</th>
                  <th class="text-left py-3 px-5 text-[9px] font-semibold text-slate-400 uppercase tracking-wider">วิชา</th>
                  <th class="text-left py-3 px-5 text-[9px] font-semibold text-slate-400 uppercase tracking-wider">ครูผู้สอน</th>
                  <th class="text-left py-3 px-5 text-[9px] font-semibold text-slate-400 uppercase tracking-wider">ห้องเรียน</th>
                  <th class="text-left py-3 px-5 text-[9px] font-semibold text-slate-400 uppercase tracking-wider">ภาค/ปี</th>
                  <th class="text-right py-3 px-5 text-[9px] font-semibold text-slate-400 uppercase tracking-wider">จัดการ</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <% schedules.forEach(function(sc) { %>
                <tr class="hover:bg-slate-50/50 transition-colors duration-100">
                  <td class="py-3 px-5 font-mono text-xs text-slate-400">#<%= sc.ID %></td>
                  <td class="py-3 px-5">
                    <span class="inline-flex items-center px-2 py-0.5 border rounded text-xs font-semibold <%= DAY_COLOR[sc.day] || 'bg-slate-50 text-slate-500 border-slate-200/60' %>">
                      <%= DAY_TH[sc.day] || sc.day %>
                    </span>
                  </td>
                  <td class="py-3 px-5 font-mono text-xs text-slate-600 font-semibold">
                    คาบ <%= sc.period %>
                  </td>
                  <td class="py-3 px-5">
                    <span class="inline-flex items-center px-2 py-0.5 border rounded text-xs font-medium <%= TYPE_COLOR[sc.type] || 'bg-slate-50 text-slate-400 border-slate-200/60' %>">
                      <%= TYPE_TH[sc.type] || sc.type %>
                    </span>
                  </td>
                  <td class="py-3 px-5">
                    <% if (sc.subject_name) { %>
                      <div>
                        <p class="text-xs font-semibold text-slate-700"><%= sc.subject_name %></p>
                        <p class="font-mono text-[10px] text-slate-400"><%= sc.subject_id %></p>
                      </div>
                    <% } else { %>
                      <span class="text-slate-300 text-xs">—</span>
                    <% } %>
                  </td>
                  <td class="py-3 px-5">
                    <% if (sc.first_name) { %>
                      <div class="flex items-center gap-2">
                        <div class="w-5 h-5 rounded-full bg-slate-100 border border-slate-200/60 flex items-center justify-center flex-shrink-0">
                          <span class="text-[9px] font-bold text-slate-500"><%= sc.first_name.charAt(0) %></span>
                        </div>
                        <span class="text-xs text-slate-600"><%= sc.first_name %> <%= sc.last_name %></span>
                      </div>
                    <% } else { %>
                      <span class="text-slate-300 text-xs">—</span>
                    <% } %>
                  </td>
                  <td class="py-3 px-5">
                    <% if (sc.room_name) { %>
                      <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-slate-50 text-slate-500 border border-slate-200/60 rounded text-xs font-medium">
                        <%- hi('building-office', 'h-3 w-3') %><%= sc.room_name %>
                      </span>
                    <% } else { %>
                      <span class="text-slate-300 text-xs">—</span>
                    <% } %>
                  </td>
                  <td class="py-3 px-5 font-mono text-xs text-slate-500">
                    <%= sc.semester %>/<%= sc.year %>
                  </td>
                  <td class="py-3 px-5">
                    <div class="flex items-center justify-end gap-1.5">
                      <a href="/schedules/<%= sc.ID %>/edit"
                        class="inline-flex items-center gap-1 px-2.5 py-1.5 bg-slate-50 hover:bg-slate-100 text-slate-500 hover:text-slate-700 border border-slate-200/60 rounded-lg text-[11px] font-semibold transition">
                        <%- hi('pencil-square', 'h-3 w-3') %>แก้ไข
                      </a>
                      <form action="/schedules/<%= sc.ID %>/delete" method="POST"
                        onsubmit="return confirm('ยืนยันการลบรายการนี้?')" class="inline">
                        <button type="submit"
                          class="inline-flex items-center gap-1 px-2.5 py-1.5 bg-slate-50 hover:bg-red-50 text-slate-400 hover:text-red-500 border border-slate-200/60 hover:border-red-200/60 rounded-lg text-[11px] font-semibold transition">
                          <%- hi('trash', 'h-3 w-3') %>ลบ
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </main>
  </div>

</body>
</html>
