<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | ระบบบริหารจัดการโรงเรียน</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: { extend: { fontFamily: { kanit: ['Kanit', 'sans-serif'] } } }
    }
  </script>
</head>
<body class="font-kanit bg-gray-50">

  <% const activePage = 'schedules'; %>
  <%- include('../partials/sidebar', { activePage }) %>

  <%
    const DAY_TH = { Monday:'จันทร์', Tuesday:'อังคาร', Wednesday:'พุธ',
                     Thursday:'พฤหัสบดี', Friday:'ศุกร์', Saturday:'เสาร์', Sunday:'อาทิตย์' };
  %>

  <div class="ml-16 flex flex-col h-screen overflow-hidden">

    <header class="bg-white border-b border-slate-200/60 px-8 py-4 flex items-center justify-between flex-shrink-0">
      <div>
        <h1 class="text-sm font-semibold text-slate-800 tracking-tight">แก้ไขตารางสอน</h1>
        <p class="text-[11px] text-slate-400 mt-0.5">
          <a href="/dashboard" class="hover:text-slate-600 transition-colors">หน้าหลัก</a>
          <span class="mx-1.5 text-slate-300">/</span>
          <a href="/schedules" class="hover:text-slate-600 transition-colors">ตารางสอน</a>
          <span class="mx-1.5 text-slate-300">/</span>แก้ไข #<%= schedule.ID %>
        </p>
      </div>
      <a href="/schedules" class="inline-flex items-center gap-1.5 px-3.5 py-2 border border-slate-200/60 bg-white hover:bg-slate-50 text-slate-500 hover:text-slate-700 font-semibold rounded-lg text-xs transition">
        <%- hi('arrow-left', 'h-3.5 w-3.5') %>ย้อนกลับ
      </a>
    </header>

    <main class="flex-1 overflow-y-auto px-8 py-10">
      <div class="max-w-3xl mx-auto">

        <% if (error_msg && error_msg.length > 0) { %>
          <div class="flex items-center gap-2 bg-red-50 border border-red-200/60 text-red-600 rounded-lg px-4 py-3 mb-6 text-xs">
            <%- hi('exclamation-circle', 'h-3.5 w-3.5 flex-shrink-0') %><span><%= error_msg %></span>
          </div>
        <% } %>

        <!-- Page Header -->
        <div class="flex items-center gap-4 mb-8">
          <div class="w-11 h-11 rounded-full bg-slate-100 border border-slate-200/60 flex items-center justify-center flex-shrink-0">
            <%- hi('calendar-days', 'h-5 w-5 text-slate-500') %>
          </div>
          <div>
            <h2 class="font-semibold text-slate-800 text-base leading-tight">
              <%= DAY_TH[schedule.day] || schedule.day %> — คาบ <%= schedule.period %>
            </h2>
            <p class="font-mono text-[10px] text-slate-400 mt-0.5">schedule_id: #<%= schedule.ID %></p>
          </div>
        </div>

        <div class="bg-white rounded-xl border border-slate-200/60 overflow-hidden">

          <div class="px-6 py-4 border-b border-slate-100">
            <div class="flex items-center gap-2.5">
              <div class="w-7 h-7 bg-slate-50 border border-slate-200/60 rounded-lg flex items-center justify-center">
                <%- hi('pencil-square', 'h-3.5 w-3.5 text-slate-500') %>
              </div>
              <p class="font-semibold text-slate-700 text-sm">แก้ไขข้อมูล</p>
            </div>
          </div>

          <form action="/schedules/<%= schedule.ID %>/edit" method="POST" class="p-6 space-y-6">

            <!-- Section 1: วัน & คาบ -->
            <div>
              <p class="text-[9px] font-semibold text-slate-400 uppercase tracking-[0.16em] mb-4 flex items-center gap-1.5">
                <%- hi('clock', 'h-3 w-3') %>วัน & คาบเรียน
              </p>
              <div class="grid grid-cols-2 gap-4">

                <div>
                  <label class="block text-xs font-semibold text-slate-600 mb-1.5">
                    วันสอน <span class="text-slate-400 font-normal">*</span>
                  </label>
                  <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                      <%- hi('calendar', 'h-3.5 w-3.5 text-slate-400') %>
                    </div>
                    <select name="day" required
                      class="w-full pl-9 pr-3.5 py-2.5 border border-slate-200/60 rounded-lg text-sm text-slate-700 bg-slate-50 focus:outline-none focus:ring-1 focus:ring-slate-300 focus:border-slate-300 focus:bg-white transition appearance-none cursor-pointer">
                      <% ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'].forEach(d => { %>
                        <option value="<%= d %>" <%= schedule.day === d ? 'selected' : '' %>>
                          <%= DAY_TH[d] %>
                        </option>
                      <% }) %>
                    </select>
                  </div>
                </div>

                <div>
                  <label class="block text-xs font-semibold text-slate-600 mb-1.5">
                    คาบที่ <span class="text-slate-400 font-normal">*</span>
                  </label>
                  <input
                    type="number" name="period" value="<%= schedule.period %>" min="1" max="20" required
                    class="w-full px-3.5 py-2.5 border border-slate-200/60 rounded-lg text-sm text-slate-800 bg-slate-50 focus:outline-none focus:ring-1 focus:ring-slate-300 focus:border-slate-300 focus:bg-white transition font-mono"
                  >
                </div>

                <div>
                  <label class="block text-xs font-semibold text-slate-600 mb-1.5">
                    ประเภท <span class="text-slate-400 font-normal">*</span>
                  </label>
                  <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                      <%- hi('tag', 'h-3.5 w-3.5 text-slate-400') %>
                    </div>
                    <select name="type" required
                      class="w-full pl-9 pr-3.5 py-2.5 border border-slate-200/60 rounded-lg text-sm text-slate-700 bg-slate-50 focus:outline-none focus:ring-1 focus:ring-slate-300 focus:border-slate-300 focus:bg-white transition appearance-none cursor-pointer">
                      <option value="Class"   <%= schedule.type === 'Class'   ? 'selected' : '' %>>เรียน (Class)</option>
                      <option value="Meeting" <%= schedule.type === 'Meeting' ? 'selected' : '' %>>ประชุม (Meeting)</option>
                      <option value="Other"   <%= schedule.type === 'Other'   ? 'selected' : '' %>>อื่นๆ (Other)</option>
                    </select>
                  </div>
                </div>

                <div>
                  <label class="block text-xs font-semibold text-slate-600 mb-1.5">ห้องเรียน</label>
                  <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                      <%- hi('building-office', 'h-3.5 w-3.5 text-slate-400') %>
                    </div>
                    <select name="room_id"
                      class="w-full pl-9 pr-3.5 py-2.5 border border-slate-200/60 rounded-lg text-sm text-slate-700 bg-slate-50 focus:outline-none focus:ring-1 focus:ring-slate-300 focus:border-slate-300 focus:bg-white transition appearance-none cursor-pointer">
                      <option value="">— ไม่ระบุ —</option>
                      <% rooms.forEach(r => { %>
                        <option value="<%= r.room_id %>" <%= schedule.room_id == r.room_id ? 'selected' : '' %>>
                          <%= r.room_name %> (ม.<%= r.grade_level %>)
                        </option>
                      <% }) %>
                    </select>
                  </div>
                </div>

              </div>
            </div>

            <hr class="border-slate-100">

            <!-- Section 2: วิชาและภาคเรียน -->
            <div>
              <p class="text-[9px] font-semibold text-slate-400 uppercase tracking-[0.16em] mb-4 flex items-center gap-1.5">
                <%- hi('book-open', 'h-3 w-3') %>วิชาและภาคการศึกษา
              </p>
              <div class="grid grid-cols-2 gap-4">

                <div class="col-span-2">
                  <label class="block text-xs font-semibold text-slate-600 mb-1.5">วิชา</label>
                  <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                      <%- hi('book-open', 'h-3.5 w-3.5 text-slate-400') %>
                    </div>
                    <select name="subject_id"
                      class="w-full pl-9 pr-3.5 py-2.5 border border-slate-200/60 rounded-lg text-sm text-slate-700 bg-slate-50 focus:outline-none focus:ring-1 focus:ring-slate-300 focus:border-slate-300 focus:bg-white transition appearance-none cursor-pointer">
                      <option value="">— ไม่ระบุวิชา —</option>
                      <% subjects.forEach(s => { %>
                        <option value="<%= s.subject_id %>" <%= schedule.subject_id === s.subject_id ? 'selected' : '' %>>
                          [<%= s.subject_id %>] <%= s.subject_name %> — ม.<%= s.grade_level %>
                          <% if (s.first_name) { %> · <%= s.first_name %> <%= s.last_name %><% } %>
                        </option>
                      <% }) %>
                    </select>
                  </div>
                  <p class="text-[10px] text-slate-400 mt-1.5">ชื่อครูผู้สอนจะตามวิชาที่เลือกโดยอัตโนมัติ</p>
                </div>

                <div>
                  <label class="block text-xs font-semibold text-slate-600 mb-1.5">
                    ภาคเรียน <span class="text-slate-400 font-normal">*</span>
                  </label>
                  <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                      <%- hi('calendar', 'h-3.5 w-3.5 text-slate-400') %>
                    </div>
                    <select name="semester" required
                      class="w-full pl-9 pr-3.5 py-2.5 border border-slate-200/60 rounded-lg text-sm text-slate-700 bg-slate-50 focus:outline-none focus:ring-1 focus:ring-slate-300 focus:border-slate-300 focus:bg-white transition appearance-none cursor-pointer">
                      <option value="1" <%= schedule.semester == 1 ? 'selected' : '' %>>ภาคเรียนที่ 1</option>
                      <option value="2" <%= schedule.semester == 2 ? 'selected' : '' %>>ภาคเรียนที่ 2</option>
                    </select>
                  </div>
                </div>

                <div>
                  <label class="block text-xs font-semibold text-slate-600 mb-1.5">
                    ปีการศึกษา <span class="text-slate-400 font-normal">*</span>
                  </label>
                  <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none">
                      <%- hi('calendar-days', 'h-3.5 w-3.5 text-slate-400') %>
                    </div>
                    <select name="year" required
                      class="w-full pl-9 pr-3.5 py-2.5 border border-slate-200/60 rounded-lg text-sm text-slate-700 bg-slate-50 focus:outline-none focus:ring-1 focus:ring-slate-300 focus:border-slate-300 focus:bg-white transition appearance-none cursor-pointer">
                      <% years.forEach(y => { %>
                        <option value="<%= y.year %>" <%= schedule.year == y.year ? 'selected' : '' %>>
                          <%= y.year %>
                        </option>
                      <% }) %>
                    </select>
                  </div>
                </div>

              </div>
            </div>

            <div class="flex items-center justify-end gap-2.5 pt-2 border-t border-slate-100">
              <a href="/schedules"
                class="px-4 py-2 border border-slate-200/60 bg-white hover:bg-slate-50 text-slate-400 hover:text-slate-600 font-semibold rounded-lg text-xs transition">
                ยกเลิก
              </a>
              <button type="submit"
                class="inline-flex items-center gap-1.5 px-4 py-2 bg-slate-800 hover:bg-slate-700 text-white font-semibold rounded-lg text-xs transition">
                <%- hi('check', 'h-3.5 w-3.5') %>บันทึกการแก้ไข
              </button>
            </div>

          </form>
        </div>

      </div>
    </main>
  </div>

</body>
</html>
