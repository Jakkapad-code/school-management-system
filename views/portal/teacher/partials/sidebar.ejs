<%
  var _page = (typeof activePage !== 'undefined') ? activePage : '';
  function navCls(name) {
    return _page === name
      ? 'flex items-center gap-3 px-3 py-2 rounded-lg text-xs font-semibold text-gray-900 bg-gray-100'
      : 'flex items-center gap-3 px-3 py-2 rounded-lg text-xs font-medium text-gray-500 hover:text-gray-900 hover:bg-gray-50 transition-colors duration-150';
  }
%>

<aside class="group fixed left-0 top-0 h-full w-16 hover:w-64 transition-all duration-300 ease-in-out bg-white border-r border-gray-200 flex flex-col z-50 overflow-hidden">

  <!-- Logo -->
  <div class="h-14 px-4 border-b border-gray-200 flex items-center gap-3 flex-shrink-0">
    <div class="w-8 h-8 bg-gray-900 rounded-lg flex items-center justify-center flex-shrink-0">
      <%- hi('academic-cap', 'h-4 w-4 text-white') %>
    </div>
    <div class="opacity-0 group-hover:opacity-100 transition-opacity duration-200 whitespace-nowrap">
      <p class="text-sm font-bold text-gray-900 leading-none tracking-tight">HSM</p>
      <p class="text-[10px] text-gray-400 mt-0.5">Teacher Portal</p>
    </div>
  </div>

  <!-- Navigation -->
  <nav class="flex-1 px-2 py-4 space-y-0.5 overflow-y-auto overflow-x-hidden">

    <p class="opacity-0 group-hover:opacity-100 transition-opacity duration-200 text-[9px] text-gray-400 font-semibold uppercase tracking-[0.14em] px-3 mb-1.5 whitespace-nowrap">เมนูหลัก</p>

    <a href="/teacher/dashboard" class="<%= navCls('dashboard') %>">
      <div class="flex-shrink-0 w-8 flex items-center justify-center">
        <%- hi('calendar-days', 'h-4 w-4') %>
      </div>
      <span class="opacity-0 group-hover:opacity-100 transition-opacity duration-200 whitespace-nowrap">ตารางสอนของฉัน</span>
    </a>

    <p class="opacity-0 group-hover:opacity-100 transition-opacity duration-200 text-[9px] text-gray-400 font-semibold uppercase tracking-[0.14em] px-3 pt-4 pb-1.5 whitespace-nowrap">ห้องเรียน</p>

    <a href="/teacher/attendance" class="<%= navCls('attendance') %>">
      <div class="flex-shrink-0 w-8 flex items-center justify-center">
        <%- hi('clipboard-document-check', 'h-4 w-4') %>
      </div>
      <span class="opacity-0 group-hover:opacity-100 transition-opacity duration-200 whitespace-nowrap">เช็คชื่อ</span>
    </a>

    <a href="/teacher/grades" class="<%= navCls('grades') %>">
      <div class="flex-shrink-0 w-8 flex items-center justify-center">
        <%- hi('pencil-square', 'h-4 w-4') %>
      </div>
      <span class="opacity-0 group-hover:opacity-100 transition-opacity duration-200 whitespace-nowrap">บันทึกคะแนน</span>
    </a>

  </nav>

  <!-- User + Logout -->
  <div class="px-2 py-3 border-t border-gray-200 flex-shrink-0">
    <div class="flex items-center gap-3 px-3 py-2 rounded-lg mb-0.5">
      <div class="w-8 h-8 rounded-full bg-gray-100 border border-gray-200 flex items-center justify-center flex-shrink-0">
        <%- hi('user', 'h-3.5 w-3.5 text-gray-500') %>
      </div>
      <div class="opacity-0 group-hover:opacity-100 transition-opacity duration-200 whitespace-nowrap overflow-hidden">
        <p class="text-xs font-semibold text-gray-800 truncate leading-none"><%= currentUser ? currentUser.username : '-' %></p>
        <p class="text-[10px] text-gray-400 truncate mt-0.5">Teacher</p>
      </div>
    </div>
    <a href="/logout" class="flex items-center gap-3 px-3 py-2 rounded-lg text-xs font-medium text-gray-500 hover:text-gray-900 hover:bg-gray-50 transition-colors duration-150">
      <div class="flex-shrink-0 w-8 flex items-center justify-center">
        <%- hi('arrow-right-on-rectangle', 'h-4 w-4') %>
      </div>
      <span class="opacity-0 group-hover:opacity-100 transition-opacity duration-200 whitespace-nowrap">ออกจากระบบ</span>
    </a>
  </div>

</aside>
