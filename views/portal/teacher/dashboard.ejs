<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Teacher Portal</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: { extend: { fontFamily: { kanit: ['Kanit', 'sans-serif'] } } }
    }
  </script>
</head>
<body class="font-kanit bg-gray-50">

  <% const activePage = 'dashboard'; %>
  <%- include('./partials/sidebar', { activePage }) %>

  <%
    const DAY_KEYS = ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'];
    const DAY_TH   = { Monday:'จันทร์', Tuesday:'อังคาร', Wednesday:'พุธ',
                       Thursday:'พฤหัสบดี', Friday:'ศุกร์', Saturday:'เสาร์', Sunday:'อาทิตย์' };
    const DAY_COLOR = {
      Monday:    { bg:'bg-blue-50',    border:'border-blue-200/60',   text:'text-blue-700',   dot:'bg-blue-400' },
      Tuesday:   { bg:'bg-pink-50',    border:'border-pink-200/60',   text:'text-pink-700',   dot:'bg-pink-400' },
      Wednesday: { bg:'bg-emerald-50', border:'border-emerald-200/60',text:'text-emerald-700',dot:'bg-emerald-400' },
      Thursday:  { bg:'bg-orange-50',  border:'border-orange-200/60', text:'text-orange-700', dot:'bg-orange-400' },
      Friday:    { bg:'bg-yellow-50',  border:'border-yellow-200/60', text:'text-yellow-700', dot:'bg-yellow-500' },
      Saturday:  { bg:'bg-purple-50',  border:'border-purple-200/60', text:'text-purple-700', dot:'bg-purple-400' },
      Sunday:    { bg:'bg-red-50',     border:'border-red-200/60',    text:'text-red-700',    dot:'bg-red-400' },
    };
    const TYPE_TH = { Class:'เรียน', Meeting:'ประชุม', Other:'อื่นๆ' };
  %>

  <div class="ml-16 flex flex-col h-screen overflow-hidden">

    <!-- Top Header -->
    <header class="bg-white border-b border-slate-200/60 px-8 py-4 flex items-center justify-between flex-shrink-0">
      <div>
        <h1 class="text-sm font-semibold text-slate-800 tracking-tight">ตารางสอนของฉัน</h1>
        <p class="text-[11px] text-slate-400 mt-0.5">Teacher Portal</p>
      </div>
      <% if (teacher) { %>
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-full bg-slate-100 border border-slate-200/60 flex items-center justify-center">
            <span class="text-slate-600 font-bold text-sm"><%= teacher.first_name.charAt(0) %></span>
          </div>
          <div class="text-right">
            <p class="text-xs font-semibold text-slate-700 leading-none"><%= teacher.first_name %> <%= teacher.last_name %></p>
            <p class="font-mono text-[10px] text-slate-400 mt-0.5"><%= totalPeriods %> คาบ/สัปดาห์</p>
          </div>
        </div>
      <% } %>
    </header>

    <main class="flex-1 overflow-y-auto p-8">

      <% if (success_msg && success_msg.length > 0) { %>
        <div class="flex items-center gap-2 bg-emerald-50 border border-emerald-200/60 text-emerald-700 rounded-lg px-4 py-3 mb-5 text-xs">
          <%- hi('check-circle', 'h-3.5 w-3.5 flex-shrink-0') %><span><%= success_msg %></span>
        </div>
      <% } %>
      <% if (error_msg && error_msg.length > 0) { %>
        <div class="flex items-center gap-2 bg-red-50 border border-red-200/60 text-red-600 rounded-lg px-4 py-3 mb-5 text-xs">
          <%- hi('exclamation-circle', 'h-3.5 w-3.5 flex-shrink-0') %><span><%= error_msg %></span>
        </div>
      <% } %>

      <% if (!teacher) { %>
        <!-- ยังไม่มี teacher record ผูกกับ account นี้ -->
        <div class="bg-white rounded-xl border border-slate-200/60 text-center py-16">
          <div class="w-12 h-12 bg-amber-50 border border-amber-200/60 rounded-xl flex items-center justify-center mx-auto mb-4">
            <%- hi('exclamation-triangle', 'h-5 w-5 text-amber-500') %>
          </div>
          <p class="font-semibold text-slate-700 text-sm">ยังไม่ได้เชื่อมข้อมูลครู</p>
          <p class="text-slate-400 text-xs mt-1.5 max-w-xs mx-auto">
            บัญชีนี้ยังไม่ได้ถูกผูกกับข้อมูลครูในระบบ กรุณาติดต่อผู้ดูแลระบบเพื่อเชื่อมข้อมูล
          </p>
        </div>
      <% } else if (totalPeriods === 0) { %>
        <!-- มี teacher record แต่ยังไม่มีตารางสอน -->
        <div class="bg-white rounded-xl border border-slate-200/60 text-center py-16">
          <div class="w-12 h-12 bg-slate-50 border border-slate-200/60 rounded-xl flex items-center justify-center mx-auto mb-4">
            <%- hi('calendar-days', 'h-5 w-5 text-slate-400') %>
          </div>
          <p class="font-semibold text-slate-600 text-sm">ยังไม่มีตารางสอน</p>
          <p class="text-slate-400 text-xs mt-1.5">ผู้ดูแลระบบยังไม่ได้จัดตารางสอนให้คุณ</p>
        </div>
      <% } else { %>

        <!-- Summary strip -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">
          <div class="bg-white border border-slate-200/60 rounded-xl px-5 py-4">
            <p class="text-[10px] font-semibold text-slate-400 uppercase tracking-wider mb-1">คาบทั้งหมด</p>
            <p class="font-mono text-2xl font-bold text-slate-800"><%= totalPeriods %></p>
            <p class="text-[10px] text-slate-400 mt-0.5">คาบ/สัปดาห์</p>
          </div>
          <%
            const activeDays = DAY_KEYS.filter(d => schedulesByDay[d] && schedulesByDay[d].length > 0);
            const subjectSet = new Set();
            DAY_KEYS.forEach(d => (schedulesByDay[d] || []).forEach(sc => { if(sc.subject_id) subjectSet.add(sc.subject_id); }));
          %>
          <div class="bg-white border border-slate-200/60 rounded-xl px-5 py-4">
            <p class="text-[10px] font-semibold text-slate-400 uppercase tracking-wider mb-1">วันที่สอน</p>
            <p class="font-mono text-2xl font-bold text-slate-800"><%= activeDays.length %></p>
            <p class="text-[10px] text-slate-400 mt-0.5">วัน/สัปดาห์</p>
          </div>
          <div class="bg-white border border-slate-200/60 rounded-xl px-5 py-4">
            <p class="text-[10px] font-semibold text-slate-400 uppercase tracking-wider mb-1">จำนวนวิชา</p>
            <p class="font-mono text-2xl font-bold text-slate-800"><%= subjectSet.size %></p>
            <p class="text-[10px] text-slate-400 mt-0.5">วิชา</p>
          </div>
          <div class="bg-white border border-slate-200/60 rounded-xl px-5 py-4">
            <p class="text-[10px] font-semibold text-slate-400 uppercase tracking-wider mb-1">ครูผู้สอน</p>
            <p class="text-sm font-semibold text-slate-700 mt-1 truncate"><%= teacher.first_name %> <%= teacher.last_name %></p>
            <% if (teacher.email) { %>
              <p class="text-[10px] text-slate-400 mt-0.5 truncate font-mono"><%= teacher.email %></p>
            <% } %>
          </div>
        </div>

        <!-- Schedule grouped by day -->
        <div class="space-y-4">
          <% DAY_KEYS.forEach(function(day) { %>
            <% const periods = schedulesByDay[day]; %>
            <% if (!periods || periods.length === 0) return; %>
            <% const c = DAY_COLOR[day]; %>

            <div class="bg-white rounded-xl border border-slate-200/60 overflow-hidden">

              <!-- Day header -->
              <div class="px-6 py-3.5 border-b border-slate-100 flex items-center gap-3">
                <span class="w-2 h-2 rounded-full <%= c.dot %> flex-shrink-0"></span>
                <p class="font-semibold text-slate-700 text-sm">วัน<%= DAY_TH[day] %></p>
                <span class="font-mono text-[10px] text-slate-400"><%= periods.length %> คาบ</span>
              </div>

              <!-- Periods list -->
              <div class="divide-y divide-slate-100">
                <% periods.forEach(function(sc) { %>
                  <div class="px-6 py-4 flex items-center gap-4 hover:bg-slate-50/50 transition-colors">

                    <!-- คาบ badge -->
                    <div class="flex-shrink-0 w-12 h-12 rounded-xl <%= c.bg %> border <%= c.border %> flex flex-col items-center justify-center">
                      <span class="text-[9px] font-semibold <%= c.text %> uppercase tracking-wide leading-none">คาบ</span>
                      <span class="font-mono font-bold text-lg <%= c.text %> leading-tight"><%= sc.period %></span>
                    </div>

                    <!-- Subject info -->
                    <div class="flex-1 min-w-0">
                      <% if (sc.subject_name) { %>
                        <p class="font-semibold text-slate-800 text-sm truncate"><%= sc.subject_name %></p>
                        <div class="flex items-center gap-2 mt-0.5">
                          <span class="font-mono text-[10px] text-slate-400"><%= sc.subject_id %></span>
                          <span class="text-slate-300 text-[10px]">·</span>
                          <span class="text-[10px] text-slate-400">ม.<%= sc.grade_level %></span>
                          <% if (sc.credit) { %>
                            <span class="text-slate-300 text-[10px]">·</span>
                            <span class="text-[10px] text-slate-400"><%= sc.credit %> หน่วยกิต</span>
                          <% } %>
                        </div>
                      <% } else { %>
                        <p class="text-sm text-slate-400"><%= TYPE_TH[sc.type] || sc.type %></p>
                      <% } %>
                    </div>

                    <!-- Room -->
                    <div class="flex-shrink-0 text-right">
                      <% if (sc.room_name) { %>
                        <span class="inline-flex items-center gap-1 px-2.5 py-1 bg-slate-50 text-slate-500 border border-slate-200/60 rounded-lg text-xs font-medium">
                          <%- hi('building-office', 'h-3 w-3') %><%= sc.room_name %>
                        </span>
                      <% } %>
                      <p class="font-mono text-[10px] text-slate-400 mt-1"><%= sc.semester %>/<%= sc.year %></p>
                    </div>

                  </div>
                <% }) %>
              </div>

            </div>
          <% }) %>
        </div>

      <% } %>
    </main>
  </div>

</body>
</html>
